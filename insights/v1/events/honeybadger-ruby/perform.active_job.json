{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "insights/v1/events/honeybadger-ruby/perform.active_job.json",
  "title": "ActiveJob: perform",
  "description": "A Rails ActiveJob job execution. One event per job run, whether it succeeded or raised.",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string",
      "const": "perform.active_job"
    },
    "job_class": {
      "type": "string",
      "description": "ActiveJob class name."
    },
    "job_id": {
      "type": "string",
      "description": "Unique job identifier."
    },
    "queue_name": {
      "type": "string",
      "description": "Queue the job ran on."
    },
    "adapter_class": {
      "type": "string",
      "description": "ActiveJob adapter class, e.g. \"SidekiqAdapter\"."
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ],
      "description": "Outcome of the job execution."
    },
    "exception_object": {
      "type": "string",
      "description": "Serialized exception if the job raised, absent on success. Present in the raw payload as a Ruby exception instance."
    },
    "duration": {
      "type": "number",
      "description": "Duration in milliseconds."
    },
    "instrumenter_id": {
      "type": "string",
      "description": "Rails instrumenter UUID."
    },
    "request_id": {
      "type": "string",
      "description": "Rails request UUID, present on any event fired during a web request context. Merged globally by the Honeybadger agent."
    }
  },
  "required": [
    "event_type",
    "job_class",
    "job_id",
    "status"
  ]
}

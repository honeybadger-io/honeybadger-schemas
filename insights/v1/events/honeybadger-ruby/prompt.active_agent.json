{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "insights/v1/events/honeybadger-ruby/prompt.active_agent.json",
  "title": "ActiveAgent: prompt",
  "description": "An LLM prompt call made via ActiveAgent. One event per completion request.",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string",
      "const": "prompt.active_agent"
    },
    "provider": {
      "type": "string",
      "description": "LLM provider name, e.g. \"openai\", \"anthropic\"."
    },
    "provider_module": {
      "type": "string",
      "description": "ActiveAgent provider module class name."
    },
    "model": {
      "type": "string",
      "description": "Model identifier, e.g. \"gpt-4o\", \"claude-3-opus\"."
    },
    "trace_id": {
      "type": "string",
      "description": "Trace ID for correlating events within a single agent run."
    },
    "message_count": {
      "type": "integer",
      "description": "Number of messages in the prompt context."
    },
    "stream": {
      "type": "boolean",
      "description": "Whether the response was streamed."
    },
    "finish_reason": {
      "type": "string",
      "description": "Stop reason returned by the provider, e.g. \"stop\", \"length\"."
    },
    "response_model": {
      "type": "string",
      "description": "Model identifier as returned by the provider response."
    },
    "response_id": {
      "type": "string",
      "description": "Provider-assigned response ID."
    },
    "temperature": {
      "type": "number",
      "description": "Sampling temperature used."
    },
    "max_tokens": {
      "type": "integer",
      "description": "Max tokens parameter."
    },
    "top_p": {
      "type": "number",
      "description": "Top-p nucleus sampling parameter."
    },
    "tool_count": {
      "type": "integer",
      "description": "Number of tools available to the model."
    },
    "has_instructions": {
      "type": "boolean",
      "description": "Whether a system instructions block was included."
    },
    "usage": {
      "type": "object",
      "description": "Token usage reported by the provider.",
      "properties": {
        "input_tokens": {
          "type": "integer"
        },
        "output_tokens": {
          "type": "integer"
        },
        "total_tokens": {
          "type": "integer"
        }
      }
    },
    "duration": {
      "type": "number",
      "description": "Duration in milliseconds."
    },
    "instrumenter_id": {
      "type": "string",
      "description": "Rails instrumenter UUID."
    },
    "request_id": {
      "type": "string",
      "description": "Rails request UUID, present on any event fired during a web request context. Merged globally by the Honeybadger agent."
    }
  },
  "required": [
    "event_type",
    "provider",
    "model"
  ]
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "insights/v1/events/honeybadger-ruby/stats.sidekiq.json",
  "title": "Sidekiq: stats",
  "description": "Periodic Sidekiq cluster statistics snapshot emitted by the Honeybadger plugin.",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string",
      "const": "stats.sidekiq"
    },
    "processed": {
      "type": "integer",
      "description": "Total jobs processed (lifetime counter)."
    },
    "failed": {
      "type": "integer",
      "description": "Total jobs failed (lifetime counter)."
    },
    "scheduled_size": {
      "type": "integer",
      "description": "Jobs in the scheduled set."
    },
    "retry_size": {
      "type": "integer",
      "description": "Jobs in the retry set."
    },
    "dead_size": {
      "type": "integer",
      "description": "Jobs in the dead set."
    },
    "processes_size": {
      "type": "integer",
      "description": "Number of running Sidekiq processes."
    },
    "default_queue_latency": {
      "type": "number",
      "description": "Latency of the default queue in seconds (Sidekiq::Stats value, not converted)."
    },
    "capacity": {
      "type": "integer",
      "description": "Total worker thread capacity across all processes."
    },
    "utilization": {
      "type": "number",
      "description": "Worker utilization ratio (0.0\u20131.0)."
    },
    "queues": {
      "type": "object",
      "description": "Per-queue stats keyed by queue name.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "latency": {
            "type": "number",
            "description": "Queue latency in milliseconds."
          },
          "depth": {
            "type": "integer",
            "description": "Number of jobs in the queue."
          },
          "busy": {
            "type": "integer",
            "description": "Jobs currently being processed from this queue."
          }
        }
      }
    },
    "request_id": {
      "type": "string",
      "description": "Rails request UUID, present on any event fired during a web request context. Merged globally by the Honeybadger agent."
    }
  },
  "required": [
    "event_type"
  ]
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "insights/v1/events/honeybadger-ruby/cache_read_multi.active_support.json",
  "title": "Cache: cache_read_multi",
  "description": "Rails ActiveSupport multi-key cache read.",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string",
      "const": "cache_read_multi.active_support"
    },
    "key": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Cache keys read."
    },
    "hits": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Keys that were cache hits."
    },
    "store": {
      "type": "string",
      "description": "Cache store class name."
    },
    "duration": {
      "type": "number",
      "description": "Duration in milliseconds."
    },
    "instrumenter_id": {
      "type": "string"
    },
    "request_id": {
      "type": "string",
      "description": "Rails request UUID, present on any event fired during a web request context. Merged globally by the Honeybadger agent."
    }
  },
  "required": [
    "event_type"
  ]
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "insights/v1/events/honeybadger-ruby/service_upload.active_storage.json",
  "title": "ActiveStorage: service_upload",
  "description": "A Rails ActiveStorage service upload operation.",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string",
      "const": "service_upload.active_storage"
    },
    "key": {
      "type": "string",
      "description": "Storage key (blob identifier)."
    },
    "service": {
      "type": "string",
      "description": "Storage service name, e.g. \"disk\", \"s3\"."
    },
    "checksum": {
      "type": "string",
      "description": "Content checksum."
    },
    "duration": {
      "type": "number",
      "description": "Duration in milliseconds."
    },
    "instrumenter_id": {
      "type": "string",
      "description": "Rails instrumenter UUID."
    },
    "request_id": {
      "type": "string",
      "description": "Rails request UUID, present on any event fired during a web request context. Merged globally by the Honeybadger agent."
    }
  },
  "required": [
    "event_type"
  ]
}

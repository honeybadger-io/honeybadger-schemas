{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "insights/v1/events/honeybadger-ruby/report.system.json",
  "title": "System: report",
  "description": "Periodic system resource snapshot (memory and load average) emitted by the Honeybadger system plugin.",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string",
      "const": "report.system"
    },
    "mem": {
      "type": "object",
      "description": "Memory statistics in megabytes.",
      "properties": {
        "total": {
          "type": "number",
          "description": "Total system memory."
        },
        "free": {
          "type": "number",
          "description": "Free memory."
        },
        "buffers": {
          "type": "number",
          "description": "Memory used for buffers."
        },
        "cached": {
          "type": "number",
          "description": "Memory used for cache."
        },
        "free_total": {
          "type": "number",
          "description": "Total available memory (free + buffers + cached)."
        }
      }
    },
    "load": {
      "type": "object",
      "description": "System load averages.",
      "properties": {
        "one": {
          "type": "number",
          "description": "1-minute load average."
        },
        "five": {
          "type": "number",
          "description": "5-minute load average."
        },
        "fifteen": {
          "type": "number",
          "description": "15-minute load average."
        }
      }
    },
    "request_id": {
      "type": "string",
      "description": "Rails request UUID, present on any event fired during a web request context. Merged globally by the Honeybadger agent."
    }
  },
  "required": [
    "event_type"
  ]
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "insights/v1/events/heroku/postgres.json",
  "title": "Heroku Postgres",
  "description": "A Heroku Postgres log line ingested via a Heroku log drain. Detected by proc_id == 'heroku-postgres'. Fields are parsed from the Heroku Postgres log format.",
  "type": "object",
  "properties": {
    "event_type":          { "type": "string", "description": "Event type derived from the log source." },
    "proc_id":             { "type": "string", "const": "heroku-postgres", "description": "Heroku process identifier — always 'heroku-postgres' for this event." },
    "source":              { "type": "string", "description": "Postgres source identifier, e.g. \"HEROKU_POSTGRESQL_CRIMSON\"." },
    "addon":               { "type": "string", "description": "Add-on name." },
    "active_connections":  { "type": "integer", "description": "Number of active database connections." },
    "waiting_connections": { "type": "integer", "description": "Number of connections waiting on a lock." },
    "index_cache_hit_rate":{ "type": "number", "description": "Index cache hit rate (0.0–1.0)." },
    "table_cache_hit_rate":{ "type": "number", "description": "Table cache hit rate (0.0–1.0)." },
    "load_avg_1m":         { "type": "number", "description": "1-minute load average." },
    "load_avg_5m":         { "type": "number", "description": "5-minute load average." },
    "load_avg_15m":        { "type": "number", "description": "15-minute load average." },
    "read_iops":           { "type": "number", "description": "Read I/O operations per second." },
    "write_iops":          { "type": "number", "description": "Write I/O operations per second." },
    "tmp_disk_used":       { "type": "integer", "description": "Bytes used on temporary disk." },
    "tmp_disk_available":  { "type": "integer", "description": "Bytes available on temporary disk." },
    "memory_total":        { "type": "integer", "description": "Total memory in bytes." },
    "memory_free":         { "type": "integer", "description": "Free memory in bytes." },
    "memory_cached":       { "type": "integer", "description": "Cached memory in bytes." },
    "memory_postgres":     { "type": "integer", "description": "Memory used by Postgres in bytes." }
  },
  "required": ["proc_id"]
}

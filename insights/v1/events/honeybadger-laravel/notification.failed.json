{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "insights/v1/events/honeybadger-laravel/notification.failed.json",
  "title": "Laravel: notification.failed",
  "description": "A notification failed to send.",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string",
      "const": "notification.failed"
    },
    "notification": {
      "type": "string",
      "description": "Notification class name."
    },
    "channel": {
      "type": "string",
      "description": "Channel that failed."
    },
    "notifiable": {
      "type": "string",
      "description": "Notifiable class name."
    },
    "queue": {
      "type": [
        "string",
        "null"
      ],
      "description": "Queue name if queued."
    },
    "requestId": {
      "type": "string",
      "description": "Request ID from the X-Request-Id or Request-Id header, or a generated UUID. Set by AssignRequestId middleware into Laravel's shared log context."
    },
    "request_id": {
      "type": "string",
      "description": "Alias \u2014 same value as requestId, present if set via event context."
    }
  },
  "required": [
    "event_type",
    "notification",
    "channel"
  ]
}

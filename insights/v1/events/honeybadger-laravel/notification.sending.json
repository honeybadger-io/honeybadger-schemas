{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "insights/v1/events/honeybadger-laravel/notification.sending.json",
  "title": "Laravel: notification.sending",
  "description": "A notification is about to be sent.",
  "x-hb": {
    "notifiers": ["honeybadger-laravel"],
    "category": "notifications",
    "component": "Notifications"
  },
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string",
      "const": "notification.sending"
    },
    "notification": {
      "type": "string",
      "description": "Notification class name.",
      "examples": [
        "App\\Notifications\\InvoicePaid"
      ]
    },
    "channel": {
      "type": "string",
      "description": "Channel the notification is sent through, e.g. \"mail\", \"slack\".",
      "examples": [
        "mail"
      ]
    },
    "notifiable": {
      "type": "string",
      "description": "Notifiable class name (the recipient model).",
      "examples": [
        "App\\Models\\User"
      ]
    },
    "queue": {
      "type": [
        "string",
        "null"
      ],
      "description": "Queue name if the notification was queued.",
      "examples": [
        "default"
      ]
    },
    "requestId": {
      "type": "string",
      "description": "Correlation ID for the request, set by the AssignRequestId middleware via Laravel's shared log context. The value comes from the Request-Id or X-Request-Id request header, or is a generated UUID. Present only when that middleware is enabled.",
      "examples": [
        "f3b2c1d0-4e5a-4b6c-8d7e-9f0a1b2c3d4e"
      ]
    }
  },
  "required": [
    "event_type",
    "notification",
    "channel"
  ]
}
